        "import hashlib\n",
        "\n",
        "def get_hash(file_path):\n",
        "    hasher = hashlib.md5()\n",
        "    with open(file_path, 'rb') as f:\n",
        "        hasher.update(f.read())\n",
        "    return hasher.hexdigest()\n",
        "\n",
        "unique_hashes = set()\n",
        "final_count = 0\n",
        "\n",
        "for filename in os.listdir(clean_dir):\n",
        "    path = os.path.join(clean_dir, filename)\n",
        "    f_hash = get_hash(path)\n",
        "    if f_hash in unique_hashes:\n",
        "        os.remove(path) # Delete duplicate\n",
        "    else:\n",
        "        unique_hashes.add(f_hash)\n",
        "        final_count += 1\n",
        "\n",
        "print(f\"✨ Deduplication complete. You now have {final_count} unique, synthesizable Verilog modules.\")"
