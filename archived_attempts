        "import os\n",
        "import json\n",
        "import shutil\n",
        "from google.colab import drive\n",
        "\n",
        "# 1. Permanent Storage Setup\n",
        "print(\"📦 Mounting Google Drive...\")\n",
        "drive.mount('/content/drive')\n",
        "save_path = '/content/drive/MyDrive/Semicon_AI_Final'\n",
        "os.makedirs(save_path, exist_ok=True)\n",
        "\n",
        "# 2. Final Filter & Instruction Formatting\n",
        "print(\"🧹 Filtering and Formatting 18k modules...\")\n",
        "final_jsonl = []\n",
        "categories = [\"Arithmetic\", \"Sequential\", \"Control\", \"Interfaces\"]\n",
        "base_dir = \"./semicon_final_dataset\"\n",
        "\n",
        "for cat in categories:\n",
        "    cat_path = os.path.join(base_dir, cat)\n",
        "    if not os.path.exists(cat_path): continue\n",
        "\n",
        "    files = os.listdir(cat_path)\n",
        "    for filename in files:\n",
        "        file_path = os.path.join(cat_path, filename)\n",
        "        with open(file_path, 'r', errors='ignore') as f:\n",
        "            code = f.read().strip()\n",
        "\n",
        "            # Filter out 'wrong' or 'empty' code\n",
        "            if len(code) < 50 or 'module' not in code.lower():\n",
        "                continue\n",
        "\n",
        "            # Create Instruction-Tuning Format (JSONL)\n",
        "            # This follows the 'Instruction/Response' pattern for LoRA\n",
        "            entry = {\n",
        "                \"instruction\": f\"Write a Verilog module for a {filename.replace('.v', '').replace('_', ' ')} logic circuit.\",\n",
        "                \"input\": \"\",\n",
        "                \"output\": code\n",
        "            }\n",
        "            final_jsonl.append(entry)\n",
        "\n",
        "# 3. Save the formatted dataset\n",
        "jsonl_file = os.path.join(save_path, 'train_dataset.jsonl')\n",
        "with open(jsonl_file, 'w') as f:\n",
        "    for entry in final_jsonl:\n",
        "        f.write(json.dumps(entry) + '\\n')\n",
        "\n",
        "# 4. Zip the raw Verilog files for the judges/presentation\n",
        "print(\"🗜️ Zipping raw modules for backup...\")\n",
        "shutil.make_archive(os.path.join(save_path, 'verilog_modules_backup'), 'zip', base_dir)\n",
        "\n",
        "print(f\"\\n🚀 DONE! Everything is saved in your Google Drive at: {save_path}\")\n",
        "print(f\"✅ Total Verified Instruction Pairs: {len(final_jsonl)}\")\n",
