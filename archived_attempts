        "import os\n",
        "import re\n",
        "\n",
        "raw_dir = \"./verilog_data\"\n",
        "clean_dir = \"./verilog_clean\"\n",
        "os.makedirs(clean_dir, exist_ok=True)\n",
        "\n",
        "# Keywords that indicate a file is a Testbench or Simulation-only (Non-Synthesizable)\n",
        "forbidden_keywords = [\n",
        "    'initial', '$display', '$finish', '$monitor', '$stop',\n",
        "    '#', 'wait', 'force', 'release', 'fork', 'join'\n",
        "]\n",
        "\n",
        "def is_synthesizable(file_path):\n",
        "    with open(file_path, 'r', errors='ignore') as f:\n",
        "        content = f.read().lower()\n",
        "        # Remove comments to avoid false positives\n",
        "        content = re.sub(r'//.*|/\\*.*?\\*/', '', content, flags=re.DOTALL)\n",
        "\n",
        "        # Check for forbidden simulation-only keywords\n",
        "        if any(kw in content for kw in forbidden_keywords):\n",
        "            return False\n",
        "        # Ensure it actually contains a module\n",
        "        if 'module' not in content or 'endmodule' not in content:\n",
        "            return False\n",
        "    return True\n",
        "\n",
        "print(\"Cleaning dataset... this will take a few minutes.\")\n",
        "clean_count = 0\n",
        "\n",
        "for filename in os.listdir(raw_dir):\n",
        "    if filename.endswith(\".v\"):\n",
        "        file_path = os.path.join(raw_dir, filename)\n",
        "\n",
        "        # Filter 1: Filename check (removes obvious testbenches)\n",
        "        if any(x in filename.lower() for x in ['_tb', 'test', 'sim', 'bench']):\n",
        "            continue\n",
        "\n",
        "        # Filter 2: Content check (removes non-synthesizable logic)\n",
        "        if is_synthesizable(file_path):\n",
        "            with open(file_path, 'r') as src, open(os.path.join(clean_dir, filename), 'w') as dst:\n",
        "                dst.write(src.read())\n",
        "            clean_count += 1\n",
        "\n",
        "print(f\"🧹 Done! Cleaned {len(os.listdir(raw_dir))} modules down to {clean_count} high-quality modules.\")"
      ],
